{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ArtifactManifest",
  "type": "object",
  "required": ["project_id", "artifacts"],
  "properties": {
    "project_id": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "type",
          "created_by",
          "source_tasks",
          "verified"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "created_by": {
            "type": "string"
          },
          "source_tasks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "verified": {
            "type": "boolean"
          },
          "path": {
            "type": "string"
          }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TaskGraph",
  "type": "object",
  "required": ["nodes"],
  "properties": {
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "task_id",
          "task_name",
          "agent",
          "status",
          "input",
          "depends_on"
        ],
        "properties": {
          "task_id": {
            "type": "string"
          },
          "task_name": {
            "type": "string"
          },
          "agent": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "running", "completed", "failed", "blocked", "retrying"]
          },
          "input": {
            "type": "object"
          },
          "output": {
            "type": ["object", "null"]
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "retry_count": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  }
}
